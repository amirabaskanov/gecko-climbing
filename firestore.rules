rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      // Owner can update anything; other users can only update follow/stat counters
      allow update: if request.auth != null &&
        (request.auth.uid == uid ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(
           ['followersCount', 'followingCount', 'totalSessions', 'totalClimbs', 'highestGrade', 'highestGradeNumeric']
         ));

      match /following/{targetUid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      match /followers/{followerUid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == followerUid;
      }
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;

      match /climbs/{climbId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
      }
    }

    // Posts — read requires auth only; feed filtering is done in-app via followed-user queries
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Owner can update anything; other users can only update like/comment counters
      allow update: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(
           ['likesCount', 'commentsCount']
         ));
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;

      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

    // Feedback — users can only create, never read/update/delete their own
    match /feedback/{feedbackId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
